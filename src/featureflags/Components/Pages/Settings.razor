@page "/settings"
@rendermode InteractiveServer
@attribute [Authorize]

@using System.Security.Claims
@using System.Security.Cryptography
@using FeatureFlags.Components.Models
@using FeatureFlags.Data
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using FeatureFlags.Services

@inject FeatureFlagDbContext Db
@inject ApplicationDbContext IdentityDb
@inject AuthenticationStateProvider AuthenticationStateProvider

@inject IProjectPermissionService PermissionService

<PageTitle>Settings</PageTitle>

<h1>Project Settings</h1>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

<div class="card p-3 mb-4">
    <h4>Add Project Member</h4>

    <div class="mb-3">
        <label class="form-label">User Email</label>
        <input class="form-control" @bind="memberEmail" />
    </div>

    <div class="mb-3">
        <label class="form-label">Role</label>
        <select class="form-select" @bind="selectedRole">
            <option value="@ProjectRole.Viewer">Viewer</option>
            <option value="@ProjectRole.Editor">Editor</option>
            <option value="@ProjectRole.Admin">Admin</option>
            <option value="@ProjectRole.Owner">Owner</option>
        </select>
    </div>

    <button class="btn btn-primary" @onclick="AddMember">Add Member</button>
</div>

<div class="card p-3 mb-4">
    <h4>Members</h4>

    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Display Name</th>
                <th>User Id</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var member in members)
            {
                <tr>
                    <td>@member.Email</td>
                    <td>@(string.IsNullOrWhiteSpace(member.DisplayName) ? "—" : member.DisplayName)</td>
                    <td><code>@member.UserId</code></td>
                    <td>@member.Role</td>
                    <td>
                        @if (member.RevokedAt is null)
                        {
                            <select class="form-select form-select-sm" value="@member.Role"
                                    @onchange="e => UpdateMemberRole(member, e)">
                                <option value="@ProjectRole.Viewer">Viewer</option>
                                <option value="@ProjectRole.Editor">Editor</option>
                                <option value="@ProjectRole.Admin">Admin</option>
                                <option value="@ProjectRole.Owner">Owner</option>
                            </select>
                        }
                    </td>

                    <td>
                        @if (member.RevokedAt is null)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RevokeMember(member)">
                                Remove
                            </button>
                        }
                        else
                        {
                            <span class="text-muted">Removed</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="card p-3 mb-4">
    <h4>API Keys</h4>
    <p class="text-muted mb-3">
        Public client keys identify this project environment when calling the feature flag API.
    </p>

    <div class="row g-3 align-items-end mb-3">
        <div class="col-md-8">
            <label class="form-label">Key Name</label>
            <input class="form-control" @bind="newKeyName" placeholder="Local dev, production app, etc." />
        </div>
        <div class="col-md-4">
            <button class="btn btn-primary w-100" @onclick="GenerateKey">Generate Key</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(generatedKey))
    {
        <div class="alert alert-success">
            <div class="fw-semibold mb-1">New key generated</div>
            <div class="small mb-2">Copy this key for your SDK/client configuration.</div>
            <code style="word-break: break-all;">@generatedKey</code>
        </div>
    }

    <table class="table">
        <thead>
            <tr>
                <th>Key Name</th>
                <th>Key</th>
                <th>Created At</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var key in keys)
            {
                <tr>
                    <td>@key.Name</td>
                    <td><code>@key.Key</code></td>
                    <td>@key.CreatedAt</td>
                    <td>@(key.RevokedAt.HasValue ? key.RevokedAt.Value.ToString() : "Active")</td>
                    <td>
                        @if (key.RevokedAt is null)
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RevokeKey(key)">
                                Revoke
                            </button>
                        }
                        else
                        {
                            <span class="text-muted">Revoked</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    private int projectId;
    private int environmentId;
    private string memberEmail = string.Empty;
    private ProjectRole selectedRole = ProjectRole.Viewer;
    private string? errorMessage;
    private string? successMessage;
    private List<ProjectMember> members = new();
    private List<ClientKey> keys = new();
    private string newKeyName = string.Empty;
    private string? generatedKey;

    protected override async Task OnInitializedAsync()
    {
        var project = await Db.Projects.OrderBy(p => p.Id).FirstAsync();
        projectId = project.Id;

        var environment = await Db.ProjectEnvironments
            .Where(e => e.ProjectId == projectId)
            .OrderBy(e => e.Id)
            .FirstAsync();
        environmentId = environment.Id;

        members = await Db.ProjectMembers
            .Where(m => m.ProjectId == projectId)
            .OrderBy(m => m.Role)
            .ToListAsync();

        keys = await Db.ClientKeys
            .Where(k => k.ProjectEnvironment.ProjectId == projectId)
            .OrderBy(k => k.CreatedAt)
            .ToListAsync();
    }

    @* API Keys *@

    private async Task GenerateKey()
    {
        errorMessage = null;
        successMessage = null;
        generatedKey = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var canManageKeys = await Db.ProjectMembers.AnyAsync(m =>
            m.ProjectId == projectId &&
            m.UserId == currentUserId &&
            (m.Role == ProjectRole.Owner || m.Role == ProjectRole.Admin));

        if (!canManageKeys)
        {
            errorMessage = "You do not have permission to manage API keys.";
            return;
        }

        var keyValue = GeneratePublicClientKey();
        var keyName = string.IsNullOrWhiteSpace(newKeyName)
            ? "Client key"
            : newKeyName.Trim();

        Db.ClientKeys.Add(new ClientKey
        {
            ProjectEnvironmentId = environmentId,
            Name = keyName,
            Key = keyValue,
            CreatedAt = DateTime.UtcNow
        });

        await Db.SaveChangesAsync();

        generatedKey = keyValue;
        newKeyName = string.Empty;
        successMessage = "API key generated.";

        keys = await Db.ClientKeys
            .Where(k => k.ProjectEnvironment.ProjectId == projectId)
            .OrderBy(k => k.CreatedAt)
            .ToListAsync();
    }

    private static string GeneratePublicClientKey()
    {
        Span<byte> bytes = stackalloc byte[24];
        RandomNumberGenerator.Fill(bytes);

        var token = Convert.ToBase64String(bytes)
            .Replace("+", "-", StringComparison.Ordinal)
            .Replace("/", "_", StringComparison.Ordinal)
            .Replace("=", string.Empty, StringComparison.Ordinal);

        return $"ff_client_{token}";
    }

    private async Task RevokeKey(ClientKey key)
    {
        errorMessage = null;
        successMessage = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var canManageKeys = await PermissionService.CanManageKeysAsync(projectId, currentUserId);

        if (!canManageKeys)
        {
            errorMessage = "You do not have permission to revoke API keys.";
            return;
        }

        var existing = await Db.ClientKeys.FindAsync(key.Id);

        if (existing is null)
        {
            errorMessage = "API key was not found.";
            return;
        }

        existing.RevokedAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();

        successMessage = "API key revoked.";

        keys = await Db.ClientKeys
            .Where(k => k.ProjectEnvironment.ProjectId == projectId)
            .OrderBy(k => k.CreatedAt)
            .ToListAsync();
    }

    @* Member Roles *@

    private async Task AddMember()
    {
        errorMessage = null;
        successMessage = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var canManageMembers = await Db.ProjectMembers.AnyAsync(m =>
            m.ProjectId == projectId &&
            m.UserId == currentUserId &&
            (m.Role == ProjectRole.Owner || m.Role == ProjectRole.Admin));

        if (!canManageMembers)
        {
            errorMessage = "You do not have permission to manage project members.";
            return;
        }

        var normalizedEmail = memberEmail.Trim().ToUpperInvariant();

        var user = await IdentityDb.Users
            .FirstOrDefaultAsync(u => u.NormalizedEmail == normalizedEmail);

        if (user is null)
        {
            errorMessage = "No registered user found with that email.";
            return;
        }

        var existingMember = await Db.ProjectMembers.FirstOrDefaultAsync(m =>
            m.ProjectId == projectId &&
            m.UserId == user.Id);

        if (existingMember is not null)
        {
            if (existingMember.RevokedAt is null)
            {
                errorMessage = "That user is already a member of this project.";
                return;
            }

            existingMember.RevokedAt = null;
            existingMember.Role = selectedRole;
            existingMember.Email = user.Email ?? memberEmail.Trim();
            existingMember.DisplayName = user.UserName ?? user.Email ?? memberEmail.Trim();

            await Db.SaveChangesAsync();
            successMessage = "Project member restored.";
            await ReloadMembers();
            return;
        }

        Db.ProjectMembers.Add(new ProjectMember
        {
            ProjectId = projectId,
            UserId = user.Id,
            Email = user.Email ?? memberEmail.Trim(),
            DisplayName = user.UserName ?? user.Email ?? memberEmail.Trim(),
            Role = selectedRole
        });

        await Db.SaveChangesAsync();

        members = await Db.ProjectMembers
            .Where(m => m.ProjectId == projectId)
            .OrderBy(m => m.Role)
            .ToListAsync();

        memberEmail = string.Empty;
        successMessage = "Project member added.";

        keys = await Db.ClientKeys
            .Where(k => k.ProjectEnvironment.ProjectId == projectId)
            .OrderBy(k => k.CreatedAt)
            .ToListAsync();
    }

    private async Task UpdateMemberRole(ProjectMember member, ChangeEventArgs e)
    {
        errorMessage = null;
        successMessage = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var canManageMembers = await PermissionService.CanManageMembersAsync(projectId, currentUserId);

        if (!canManageMembers)
        {
            errorMessage = "You do not have permission to update project members.";
            return;
        }

        if (!Enum.TryParse<ProjectRole>(e.Value?.ToString(), out var newRole))
        {
            errorMessage = "Invalid role.";
            return;
        }

        var existing = await Db.ProjectMembers.FindAsync(member.Id);

        if (existing is null)
        {
            errorMessage = "Project member was not found.";
            return;
        }

        existing.Role = newRole;
        await Db.SaveChangesAsync();

        successMessage = "Member role updated.";
        await ReloadMembers();
    }

    private async Task RevokeMember(ProjectMember member)
    {
        errorMessage = null;
        successMessage = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var canManageMembers = await PermissionService.CanManageMembersAsync(projectId, currentUserId);

        if (!canManageMembers)
        {
            errorMessage = "You do not have permission to remove project members.";
            return;
        }

        if (member.UserId == currentUserId)
        {
            errorMessage = "You cannot remove yourself from the project.";
            return;
        }

        var existing = await Db.ProjectMembers.FindAsync(member.Id);

        if (existing is null)
        {
            errorMessage = "Project member was not found.";
            return;
        }

        existing.RevokedAt = DateTime.UtcNow;
        await Db.SaveChangesAsync();

        successMessage = "Project member removed.";
        await ReloadMembers();
    }

    private async Task ReloadMembers()
    {
        members = await Db.ProjectMembers
            .Where(m => m.ProjectId == projectId)
            .OrderBy(m => m.RevokedAt != null)
            .ThenBy(m => m.Role)
            .ToListAsync();
    }
}