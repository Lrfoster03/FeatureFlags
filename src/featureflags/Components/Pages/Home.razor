@page "/"
@rendermode InteractiveServer
@using FeatureFlags.Components.Models
@using FeatureFlags.Components.Shared
@using FeatureFlags.Data
@using FeatureFlags.Services
@using Microsoft.EntityFrameworkCore
@using BlazorBootstrap
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

@inject FeatureFlagDbContext Db
@inject IFeatureFlagConfirmationService ConfirmationService
@inject IProjectPermissionService PermissionService
@inject AuthenticationStateProvider AuthenticationStateProvider

@attribute [Authorize]

<PageTitle>Feature Flags</PageTitle>

<div style="display: flex; justify-content: space-between; align-items: center; padding: 1rem;">
    <h1 style="margin: 0;">Feature Flags</h1>
    <button class="btn btn-primary" @onclick="AddItem">Add Flag</button>
</div>

<div style="overflow-y: scroll;">
    <ul class="list-group">
        @foreach (var item in itemList)
        {
            <div style="padding: 0.5rem; border-radius: 0.25rem;">
                <Pill FeatureFlag="item" OnChanged="SaveFeatureFlag" OnDelete="DeleteFeatureFlag" />
            </div>
        }
    </ul>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div style="position: fixed; bottom: 1rem; right: 1rem; z-index: 2000; min-width: 320px;">
        <Alert Color="AlertColor.Danger" Dismissable="true">
            @errorMessage
        </Alert>
    </div>
}

<ConfirmDialog @ref="confirmDialog" />

@code {
    private List<FeatureFlag> itemList = new();
    private string? errorMessage;
    private ConfirmDialog confirmDialog = default!;

    private Project? project;
    private ProjectEnvironment? environment;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (userId is null)
        {
            return;
        }

        this.project = await Db.Projects
            .Include(p => p.Environments)
            .FirstAsync();

        this.environment = project.Environments.FirstOrDefault() ?? throw new Exception("No project environment found.");

        var isMember = await Db.ProjectMembers
                    .AnyAsync(m => m.ProjectId == project.Id && m.UserId == userId);

        if (!isMember)
        {
            Db.ProjectMembers.Add(new ProjectMember
            {
                ProjectId = project.Id,
                UserId = userId,
                Email = authState.User.FindFirstValue(ClaimTypes.Email)
                    ?? authState.User.Identity?.Name
                    ?? string.Empty,
                DisplayName = authState.User.Identity?.Name
                    ?? authState.User.FindFirstValue(ClaimTypes.Email)
                    ?? string.Empty,
                Role = this.project.Members.Count == 0 ? ProjectRole.Owner : ProjectRole.Editor
            });

            await Db.SaveChangesAsync();
        }

        itemList = await Db.FeatureFlags
                    .Where(f => f.ProjectEnvironment.ProjectId == project.Id)
                    .ToListAsync();
    }

    private async Task<bool> EnsureCanEditAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        var canEdit = await PermissionService.CanEditFlagsAsync(this.project.Id, currentUserId);

        if (!canEdit)
        {
            errorMessage = "You do not have permission to edit feature flags.";
            return false;
        }

        return true;
    }

    private async Task ReloadFlagsAsync()
    {
        itemList = await Db.FeatureFlags
            .Where(f => f.ProjectEnvironmentId == this.environment!.Id)
            .OrderBy(f => f.Name)
            .ToListAsync();
    }

    private async Task AddItem()
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;


        if (this.environment is null)
        {
            errorMessage = "No project environment exists. Create a project environment first.";
            return;
        }

        var newItem = new FeatureFlag
        {
            Name = $"Item {itemList.Count + 1}",
            Description = "",
            IsEnabled = false,
            PercentageRollout = 0,
            ProjectEnvironmentId = this.environment!.Id
        };

        Db.FeatureFlags.Add(newItem);
        await Db.SaveChangesAsync();

        itemList.Add(newItem);

        await ReloadFlagsAsync();
    }

    private async Task SaveFeatureFlag(FeatureFlag featureFlag)
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;

        featureFlag.Name = featureFlag.Name.Trim();

        var duplicateExists = await Db.FeatureFlags
            .AnyAsync(f =>
                f.ProjectEnvironmentId == featureFlag.ProjectEnvironmentId &&
                f.Name == featureFlag.Name &&
                f.Id != featureFlag.Id);

        if (duplicateExists)
        {
            errorMessage = $"A feature flag named '{featureFlag.Name}' already exists.";
            return;
        }

        try
        {
            Db.FeatureFlags.Update(featureFlag);
            await Db.SaveChangesAsync();
        }
        catch (DbUpdateException)
        {
            errorMessage = $"A feature flag named '{featureFlag.Name}' already exists.";
        }

        await ReloadFlagsAsync();
    }

    private async Task DeleteFeatureFlag(FeatureFlag featureFlag)
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;

        var confirmed = await ConfirmationService.ConfirmDeleteAsync(confirmDialog, featureFlag.Name);

        if (!confirmed)
            return;

        try
        {
            var existing = await Db.FeatureFlags.FindAsync(featureFlag.Id);

            if (existing is null)
            {
                errorMessage = $"Feature flag '{featureFlag.Name}' was not found.";
                return;
            }

            Db.FeatureFlags.Remove(existing);
            await Db.SaveChangesAsync();

            itemList.RemoveAll(f => f.Id == featureFlag.Id);
        }
        catch (Exception)
        {
            errorMessage = $"Failed to delete feature flag '{featureFlag.Name}'.";
        }

        await ReloadFlagsAsync();
    }
}
