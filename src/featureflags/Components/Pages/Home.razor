@page "/projects/{ProjectId}/home"
@rendermode InteractiveServer
@using FeatureFlags.Components.Models
@using FeatureFlags.Components.Shared
@using FeatureFlags.Data
@using FeatureFlags.Services
@using Microsoft.EntityFrameworkCore
@using BlazorBootstrap
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization

@inject FeatureFlagDbContext Db
@inject IFeatureFlagConfirmationService ConfirmationService
@inject IProjectPermissionService PermissionService
@inject AuthenticationStateProvider AuthenticationStateProvider

@inject NavigationManager Navigation

@attribute [Authorize]

<PageTitle>Feature Flags</PageTitle>


<div style="overflow-y: scroll;">
    <section class="mb-4">
        <div class="d-flex align-items-center justify-content-between px-2">
            <h1 style="margin: 0;">Feature Flags</h1>
            <div class="gap-2">
                <span class="badge bg-secondary">@featureFlags.Count</span>
                <button class="btn btn-primary" @onclick="AddFlag">Add Flag</button>
            </div>
        </div>

        @if (featureFlags.Count == 0)
        {
            <div class="alert alert-info mt-3 mb-0">No feature flags have been created for this project.</div>
        }
        else
        {
            <ul class="list-group">
                @foreach (var flag in featureFlags)
                {
                    <div style="padding: 0.5rem; border-radius: 0.25rem;">
                        <FlagPill FeatureFlag="flag" OnChanged="MarkConfigDirty" OnDelete="DeleteFeatureFlag" />
                    </div>
                }
            </ul>
        }
    </section>

    <section>
        <div class="d-flex align-items-center justify-content-between px-2">
            <h1 style="margin: 0;">Configs</h1>
            <div class="gap-2">
                <span class="badge bg-secondary">@featureConfigs.Count</span>
                <button class="btn btn-primary" @onclick="AddConfig">Add Config</button>
            </div>
        </div>

        @if (featureConfigs.Count == 0)
        {
            <div class="alert alert-info mt-3 mb-0">No configs have been created for this project.</div>
        }
        else
        {
            <ul class="list-group">
                @foreach (var config in featureConfigs)
                {
                    <div style="padding: 0.5rem; border-radius: 0.25rem;">
                        <ConfigPill Config="config" OnChanged="MarkConfigDirty" OnDelete="DeleteFeatureConfig" />
                    </div>
                }
            </ul>
        }
    </section>

    @if (HasUnsavedChanges)
    {
        <div style="position: fixed; bottom: 1rem; right: 1rem; z-index: 2000; min-width: 360px;">
            <Alert Color="AlertColor.Warning">
                <div class="d-flex align-items-center justify-content-between gap-3">
                    <span>You have unsaved changes.</span>
                    <div class="d-flex gap-2">
                        <Button Color="ButtonColor.Success" Size="ButtonSize.Small" @onclick="SaveAllChanges">
                            Save
                        </Button>
                        <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="DiscardAllChanges">
                            Discard
                        </Button>
                    </div>
                </div>
            </Alert>
        </div>
    }
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div style="position: fixed; bottom: 5rem; right: 1rem; z-index: 2001; min-width: 320px;">
        <Alert Color="AlertColor.Danger" Dismissable="true">
            @errorMessage
        </Alert>
    </div>
}

<ConfirmDialog @ref="confirmDialog" />

@code {
    [Parameter]
    public string ProjectId { get; set; } = string.Empty;
    private List<FeatureFlag> featureFlags = new();
    private List<FeatureConfig> featureConfigs = new();

    // Dirty tracking for unsaved changes
    private HashSet<IConfig> dirtyConfigs = new();

    private bool HasUnsavedChanges => dirtyConfigs.Count > 0;
    private string? errorMessage;
    private ConfirmDialog confirmDialog = default!;

    private Project? project;
    private ProjectEnvironment? environment;

    protected override async Task OnInitializedAsync()
    {
        errorMessage = null;

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
        {
            var returnUrl = Uri.EscapeDataString($"/projects/{ProjectId}/home");
            Navigation.NavigateTo($"/Identity/Account/Login?returnUrl={returnUrl}", forceLoad: true);
            return;
        }

        project = await Db.Projects
            .Include(p => p.Environments)
            .FirstOrDefaultAsync(p => p.Id == ProjectId);

        if (project is null)
        {
            errorMessage = "Project was not found.";
            return;
        }

        var isMember = await Db.ProjectMembers
            .AnyAsync(m =>
                m.ProjectId == project.Id &&
                m.UserId == userId &&
                m.RevokedAt == null);

        if (!isMember)
        {
            errorMessage = "403: You do not have permission to access this project.";
            return;
        }

        environment = project.Environments.FirstOrDefault();

        if (environment is null)
        {
            errorMessage = "No project environment found for this project.";
            return;
        }

        await ReloadConfigsAsync();
    }

    private async Task<bool> EnsureCanEditAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var currentUserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (project is null)
        {
            errorMessage = "Project was not loaded.";
            return false;
        }

        var canEdit = await PermissionService.CanEditFlagsAsync(project.Id, currentUserId);

        if (!canEdit)
        {
            errorMessage = "You do not have permission to edit feature flags.";
            return false;
        }

        return true;
    }

    private async Task ReloadConfigsAsync()
    {
        if (environment is null)
        {
            featureFlags = new();
            featureConfigs = new();
            return;
        }

        featureFlags = await Db.FeatureFlags
            .Where(f => f.ProjectEnvironmentId == environment.Id)
            .OrderBy(f => f.Name)
            .ToListAsync();

        featureConfigs = await Db.Configs
            .Where(c => c.ProjectEnvironmentId == environment.Id)
            .OrderBy(c => c.Name)
            .ToListAsync();
    }

    private async Task AddFlag()
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;


        if (this.environment is null)
        {
            errorMessage = "No project environment exists. Create a project environment first.";
            return;
        }

        var newItem = new FeatureFlag
        {
            Name = $"Item {featureFlags.Count + 1}",
            Description = "",
            IsEnabled = false,
            PercentageRollout = 0,
            ProjectEnvironmentId = environment.Id
        };

        Db.FeatureFlags.Add(newItem);
        await Db.SaveChangesAsync();

        featureFlags.Add(newItem);

        await ReloadConfigsAsync();
    }

    private async Task AddConfig()
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;


        if (this.environment is null)
        {
            errorMessage = "No project environment exists. Create a project environment first.";
            return;
        }

        var newItem = new FeatureConfig(
        )
        {
            Name = $"Config {featureConfigs.Count + 1}",
            Description = "",
            ProjectEnvironmentId = environment.Id
        };

        Db.Configs.Add(newItem);
        await Db.SaveChangesAsync();

        featureConfigs.Add(newItem);

        await ReloadConfigsAsync();
    }

    private Task MarkConfigDirty(IConfig config)
    {
        dirtyConfigs.Add(config);
        return Task.CompletedTask;
    }

    private async Task DeleteFeatureFlag(FeatureFlag featureFlag)
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;

        var confirmed = await ConfirmationService.ConfirmDeleteAsync(confirmDialog, featureFlag.Name);

        if (!confirmed)
            return;

        try
        {
            var existing = await Db.FeatureFlags.FindAsync(featureFlag.Id);

            if (existing is null)
            {
                errorMessage = $"Feature flag '{featureFlag.Name}' was not found.";
                return;
            }

            Db.FeatureFlags.Remove(existing);
            await Db.SaveChangesAsync();

            featureFlags.RemoveAll(f => f.Id == featureFlag.Id);
        }
        catch (Exception)
        {
            errorMessage = $"Failed to delete feature flag '{featureFlag.Name}'.";
        }

        await ReloadConfigsAsync();
    }

    private async Task DeleteFeatureConfig(FeatureConfig featureConfig)
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;

        var confirmed = await ConfirmationService.ConfirmDeleteAsync(confirmDialog, featureConfig.Name);

        if (!confirmed)
            return;

        try
        {
            var existing = await Db.Configs.FindAsync(featureConfig.Id);

            if (existing is null)
            {
                errorMessage = $"Feature config '{featureConfig.Name}' was not found.";
                return;
            }

            Db.Configs.Remove(existing);
            await Db.SaveChangesAsync();

            featureConfigs.RemoveAll(f => f.Id == featureConfig.Id);
        }
        catch (Exception)
        {
            errorMessage = $"Failed to delete feature config '{featureConfig.Name}'.";
        }

        await ReloadConfigsAsync();
    }


    private async Task SaveAllChanges()
    {
        if (!await EnsureCanEditAsync())
            return;

        errorMessage = null;

        foreach (IConfig config in dirtyConfigs)
        {
            config.Name = config.Name.Trim();

            if (config is FeatureFlag flag)
            {
                var duplicateExists = await Db.FeatureFlags.AnyAsync(f =>
                    f.ProjectEnvironmentId == flag.ProjectEnvironmentId &&
                    f.Name == flag.Name &&
                    f.Id != flag.Id);

                if (duplicateExists)
                {
                    errorMessage = $"A feature flag named '{flag.Name}' already exists.";
                    return;
                }

                Db.FeatureFlags.Update(flag);
            }
            else if (config is FeatureConfig featureConfig)
            {
                var duplicateExists = await Db.Configs.AnyAsync(c =>
                    c.ProjectEnvironmentId == featureConfig.ProjectEnvironmentId &&
                    c.Name == featureConfig.Name &&
                    c.Id != featureConfig.Id);

                if (duplicateExists)
                {
                    errorMessage = $"A feature config named '{featureConfig.Name}' already exists.";
                    return;
                }

                Db.Configs.Update(featureConfig);
            }
        }

        try
        {
            await Db.SaveChangesAsync();
            dirtyConfigs.Clear();
            await ReloadConfigsAsync();
        }
        catch (DbUpdateException)
        {
            errorMessage = "Failed to save changes. Check for duplicate names.";
        }
    }

    private async Task DiscardAllChanges()
    {
        errorMessage = null;
        dirtyConfigs.Clear();

        Db.ChangeTracker.Clear();
        await ReloadConfigsAsync();
    }
}
