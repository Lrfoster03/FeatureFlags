@inherits LayoutComponentBase
@using System.Security.Claims
@using FeatureFlags.Components.Models
@using FeatureFlags.Data
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject FeatureFlagDbContext Db
@inject NavigationManager Navigation

<div class="page">
    @* <div class="sidebar">
        <NavMenu />
    </div> *@

    <main>
        <div class="top-row app-header">
            <div class="app-header-left">
                <a class="btn btn-outline-secondary btn-sm" href="/projects">Home</a>
                @if (availableProjects.Count > 0)
                {
                    <div class="dropdown project-switcher">
                        <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button"
                                data-bs-toggle="dropdown" aria-expanded="false">
                            @CurrentProjectName
                        </button>
                        <ul class="dropdown-menu">
                            @foreach (var project in availableProjects)
                            {
                                <li>
                                    <a class="dropdown-item @(project.Id == CurrentProjectId ? "active" : null)"
                                       href="@($"/projects/{project.Id}/home")">
                                        @project.Name
                                    </a>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>

            <AuthorizeView>
                <Authorized>
                    <div class="app-header-right">
                        <span class="user-email">@context.User.Identity?.Name</span>
                        <form method="post" action="/Identity/Account/Logout" class="d-inline">
                            <AntiforgeryToken />
                            <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
                        </form>
                        <a class="btn btn-outline-secondary btn-sm" href="@SettingsHref">Settings</a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="app-header-right">
                        <a class="btn btn-outline-primary btn-sm" href="/Identity/Account/Login">Login</a>
                        <a class="btn btn-primary btn-sm" href="/Identity/Account/Register">Sign up</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>


        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private List<Project> availableProjects = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier);

        if (string.IsNullOrWhiteSpace(userId))
            return;

        availableProjects = await Db.ProjectMembers
            .Where(m => m.UserId == userId && m.RevokedAt == null)
            .Include(m => m.Project)
            .OrderBy(m => m.Project.Name)
            .Select(m => m.Project)
            .ToListAsync();
    }

    private string? CurrentProjectId
    {
        get
        {
            var relativePath = Navigation.ToBaseRelativePath(Navigation.Uri);
            var segments = relativePath.Split('/', StringSplitOptions.RemoveEmptyEntries);

            if (segments.Length >= 2 &&
                string.Equals(segments[0], "projects", StringComparison.OrdinalIgnoreCase))
            {
                return segments[1];
            }

            return null;
        }
    }

    private string CurrentProjectName =>
        availableProjects.FirstOrDefault(p => p.Id == CurrentProjectId)?.Name ?? "Switch project";

    private string HomeHref => !string.IsNullOrWhiteSpace(CurrentProjectId)
        ? $"/projects/{CurrentProjectId}/home"
        : "/projects";

    private string SettingsHref => !string.IsNullOrWhiteSpace(CurrentProjectId)
        ? $"/projects/{CurrentProjectId}/settings"
        : "/projects";
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
