@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">
    @* <div class="sidebar">
        <NavMenu />
    </div> *@

    <main>
        <div class="top-row px-4 auth">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">@context.User.Identity?.Name</span>
                    <form method="post" action="/Identity/Account/Logout" class="d-inline">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-outline-secondary btn-sm">Logout</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a class="btn btn-outline-primary btn-sm me-2" href="/Identity/Account/Login">Login</a>
                    <a class="btn btn-primary btn-sm" href="/Identity/Account/Register">Sign up</a>
                </NotAuthorized>
            </AuthorizeView>
            <AuthorizeView>
                <Authorized>
                    <a class="btn btn-outline-secondary btn-sm me-2" href="/settings">Settings</a>
                </Authorized>
            </AuthorizeView>
        </div>


        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
