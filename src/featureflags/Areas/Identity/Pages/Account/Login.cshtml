@page
@model FeatureFlags.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="container py-5" style="max-width: 520px;">
    <h1 class="mb-4">Log in</h1>

    <form method="post" asp-route-returnUrl="@Request.Query["returnUrl"]">
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
            <label asp-for="Input.Email">Email</label>
            <span asp-validation-for="Input.Email" class="text-danger"></span>
        </div>

        <div class="form-floating mb-3">
            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
            <label asp-for="Input.Password">Password</label>
            <span asp-validation-for="Input.Password" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary w-100">Log in</button>
    </form>

    <p class="mt-3 mb-0">
        <a asp-page="./Register" asp-route-returnUrl="@Request.Query["returnUrl"]">Create an account</a>
    </p>
</div>
